#!/usr/bin/env node
import { spawnSync } from "node:child_process";

if (process.env.SKIP_E2E === "1") {
  console.log("SKIP_E2E=1: bypassing mise run verify");
  process.exit(0);
}

const result = spawnSync("mise", ["run", "verify"], { stdio: "inherit" });
if (result.error) {
  console.error(result.error.message);
  process.exit(1);
}
process.exit(result.status ?? 1);
